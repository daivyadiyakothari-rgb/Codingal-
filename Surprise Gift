</div>

<div class="page" id="p6">
<h1>🎉 Happy Birthday Mishwa 🎉</h1>
<p>This gift carries all our memories 🌸💖  
From <b>Daivya</b> → <b>Mishwa</b> 💌  
Friendship forever ✨🌈💖  
P.S. We’ve done a lot — masti, naughty little things, bunking, going late, excuses, and endless laughs 😎🔥💫  
💖 LYSMM 💖</p>
<div>
<span class="sticker">🎈</span>
<span class="sticker">💖</span>
<span class="sticker">✨</span>
<span class="sticker">💫</span>
</div>
<br>
<button onclick="showSecret()">💖 Secret Surprise 💖</button>
</div>

<script>
let page=1;
function nextPage(){
  document.getElementById("p"+page).classList.remove("active");
  page++;
  if(page>6) page=6;
  document.getElementById("p"+page).classList.add("active");
}

// Sparkles + emoji popping
function sparkles(){
  const elements = ["✨","💖","🌸","🎉","💫","🔥","🤣"];
  const s=document.createElement("div");
  s.className="sparkle";
  s.innerHTML = elements[Math.floor(Math.random()*elements.length)];
  s.style.left=Math.random()*100+"vw";
  s.style.fontSize=(15+Math.random()*25)+"px";
  document.body.appendChild(s);
  setTimeout(()=>s.remove(),6000);
}
setInterval(sparkles,200);

// Secret Surprise with confetti
function showSecret(){
  const colors = ['#ff4fa3','#ffeb3b','#00e676','#2979ff','#ff6d00'];
  const confettiCount = 150;
  for(let i=0;i<confettiCount;i++){
    const c = document.createElement('div');
    c.style.position='absolute';
    c.style.width='10px';
    c.style.height='10px';
    c.style.backgroundColor = colors[Math.floor(Math.random()*colors.length)];
    c.style.top = Math.random()*100+'vh';
    c.style.left = Math.random()*100+'vw';
    c.style.opacity = Math.random();
    c.style.borderRadius='50%';
    c.style.animation = `confetti-fall ${2+Math.random()*3}s linear forwards`;
    document.body.appendChild(c);
    setTimeout(()=>c.remove(),5000);
  }
  alert("🎉 Surprise! Friendship forever from Daivya 💖🌸🎈✨\nRemember all our masti, bunking, going late, excuses, and endless laughs 😎🔥💫\n💖 LYSMM 💖");
}
</script>

</body>
</html>
